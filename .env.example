# Public client configuration
NEXT_PUBLIC_ENVIROMENT="development"
NEXT_PUBLIC_API_BASE_URL="https://api.example.com/api/v1"
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="replace_with_your_recaptcha_site_key"

# Server-only secrets
RECAPTCHA_SECRET="replace_with_your_recaptcha_secret"
SUPABASE_HOST="https://your-project.supabase.co"
SUPABASE_PASSWORD="replace_with_your_supabase_anon_key"
SUPABASE_PASSWORD_ADMIN="replace_with_your_supabase_service_role_key"

# CORS: comma-separated exact origins. Wildcard origins are not accepted.
ALLOWED_ORIGINS="http://localhost:3000"

# Email service
EMAIL_HOST="smtp.example.com"
EMAIL_PORT="587"
EMAIL_USER="replace_with_your_email_user"
EMAIL_PASSWORD="replace_with_your_email_password"
EMAIL_FROM="app@example.com"
